<script>

const THENEWSAPI_KEY = "tNrfLvxjfFINOVkORmAmVORoT0cP2IqrGOpgQzPU";

let currentCategory = 'general';
let isLoading = false;

const categoryMapping = {
    general: "general",
    us: "general",
    world: "general",
    politics: "politics",
    business: "business",
    technology: "technology",
    science: "science",
    health: "health",
    sports: "sports",
    entertainment: "entertainment",
    environment: "science"
};

const categoryLabels = {
    general: 'ALL GLOBAL',
    us: 'UNITED STATES',
    world: 'WORLD NEWS',
    politics: 'POLITICS',
    business: 'BUSINESS',
    technology: 'TECHNOLOGY',
    science: 'SCIENCE',
    health: 'HEALTH',
    sports: 'SPORTS',
    entertainment: 'CULTURE',
    environment: 'CLIMATE & ENVIRONMENT'
};

function getTimeAgo(dateStr) {
    const seconds = Math.floor((new Date() - new Date(dateStr)) / 1000);
    if (seconds < 60) return 'NOW';
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes}M`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}H`;
    const days = Math.floor(hours / 24);
    return `${days}D`;
}

function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function cleanDescription(text) {
    if (!text) return '';
    let cleaned = text.replace(/<[^>]*>/g, '');
    cleaned = cleaned.replace(/\[.*?\]/g, '');
    cleaned = cleaned.length > 160 ? cleaned.substring(0, 160) + '...' : cleaned;
    if (cleaned.length < 25) return "Full article available at source.";
    return cleaned;
}

async function fetchMultiSource(category, categoryType) {
    const allArticles = [];
    
    const countries = ['us', 'gb', 'ca', 'au', 'in'];
    
    const targetCountries = (category === 'us') ? ['us'] : countries;
    
    const fetchPromises = targetCountries.map(async (country) => {
        try {
            let url = `https://api.thenewsapi.com/v1/news/top?locale=${country}&language=en&limit=25&api_token=${THENEWSAPI_KEY}`;
            
            // Add category filter if not general
            if (categoryType && category !== 'general' && category !== 'us' && category !== 'world') {
                url = `https://api.thenewsapi.com/v1/news/top?locale=${country}&language=en&limit=25&categories=${categoryType}&api_token=${THENEWSAPI_KEY}`;
            }
            
            const response = await fetch(url);
            const data = await response.json();
            
            if (data.data && data.data.length > 0) {
                return data.data.map(article => ({
                    ...article,
                    sourceCountry: country.toUpperCase()
                }));
            }
            return [];
        } catch (e) {
            console.warn(`Failed to fetch from ${country}`);
            return [];
        }
    });
    
    const results = await Promise.all(fetchPromises);
    results.forEach(articles => allArticles.push(...articles));
    
    return allArticles;
}

async function fetchRSSFallback() {
    const rssSources = [
        { name: "BBC World", url: "https://feeds.bbci.co.uk/news/world/rss.xml" },
        { name: "Al Jazeera", url: "https://www.aljazeera.com/xml/rss/all.xml" }
    ];
    
    const rssArticles = [];
    
    for (const source of rssSources) {
        try {
            const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(source.url)}`;
            const response = await fetch(proxyUrl);
            const data = await response.json();
            
            if (data.contents) {
                const parser = new DOMParser();
                const xmlDoc = parser.parseFromString(data.contents, "text/xml");
                const items = xmlDoc.querySelectorAll("item");
                
                for (let i = 0; i < Math.min(items.length, 5); i++) {
                    const item = items[i];
                    const title = item.querySelector("title")?.textContent || "";
                    const link = item.querySelector("link")?.textContent || "";
                    const description = item.querySelector("description")?.textContent || "";
                    const pubDate = item.querySelector("pubDate")?.textContent || "";
                    
                    if (title && link) {
                        rssArticles.push({
                            title: title,
                            url: link,
                            description: description,
                            published_at: pubDate,
                            source: source.name,
                            sourceCountry: "RSS"
                        });
                    }
                }
            }
        } catch (e) {
            console.warn(`RSS failed for ${source.name}`);
        }
    }
    
    return rssArticles;
}

async function loadNews(category) {
    if (isLoading) return;
    isLoading = true;
    
    currentCategory = category;
    document.getElementById("currentCategoryLabel").innerText = categoryLabels[category] || category.toUpperCase();
    
    const feedDiv = document.getElementById("newsFeed");
    feedDiv.innerHTML = '<div class="loading-state"><div class="loading-dot"></div><div class="loading-dot"></div><div class="loading-dot"></div><div style="margin-top: 14px;">FETCHING 75+ STORIES FROM MULTIPLE SOURCES</div></div>';
    
    try {
        const categoryType = categoryMapping[category] || "general";
        
        let allArticles = await fetchMultiSource(category, categoryType);
        
        const rssArticles = await fetchRSSFallback();
        allArticles.push(...rssArticles);
        
        const uniqueArticles = [];
        const titles = new Set();
        for (const article of allArticles) {
            const titleKey = article.title?.substring(0, 80).toLowerCase();
            if (titleKey && !titles.has(titleKey)) {
                titles.add(titleKey);
                uniqueArticles.push(article);
            }
        }
        
        uniqueArticles.sort((a, b) => new Date(b.published_at || b.pubDate) - new Date(a.published_at || a.pubDate));
        
        const topArticles = uniqueArticles.slice(0, 75);
        
        if (topArticles.length === 0) {
            feedDiv.innerHTML = '<div class="loading-state" style="color:#FFD700;">No articles found. Try another category.</div>';
            document.getElementById("articleCount").innerHTML = "0 STORIES";
            document.getElementById("sourceStats").innerHTML = "❌ NO ARTICLES";
            isLoading = false;
            return;
        }
        
        document.getElementById("articleCount").innerHTML = `${topArticles.length} STORIES`;
        document.getElementById("sourceStats").innerHTML = `🟡 ${topArticles.length} ARTICLES · MULTI-COUNTRY AGGREGATION`;
        
        feedDiv.innerHTML = '';
        
        topArticles.forEach((article, idx) => {
            const card = document.createElement("div");
            card.className = "news-card";
            
            const description = cleanDescription(article.description || article.snippet || "");
            const sourceName = article.source || article.sourceName || "Global News";
            const region = article.sourceCountry || "GLOBAL";
            const timeAgo = getTimeAgo(article.published_at || article.pubDate || new Date());
            const articleUrl = article.url || article.link || "#";
            
            card.innerHTML = `
                <div class="card-meta">
                    <span class="card-category">${categoryLabels[category]}</span>
                    <span class="card-region">${escapeHtml(region)}</span>
                    <span class="card-source">${escapeHtml(sourceName)}</span>
                    <span class="card-time">+${timeAgo}</span>
                </div>
                <div class="card-headline">
                    <a href="${articleUrl}" target="_blank" rel="noopener noreferrer">${escapeHtml(article.title)}</a>
                </div>
                <div class="card-summary">${escapeHtml(description)}</div>
                <div class="card-divider"></div>
            `;
            
            feedDiv.appendChild(card);
        });
        
        const headlines = topArticles.slice(0, 15).map(a => a.title);
        const tickerText = [...headlines, ...headlines].join("  ◆  ");
        document.getElementById("tickerText").innerHTML = tickerText;
        
        document.getElementById("lastUpdatedDisplay").innerHTML = `LAST SCAN: ${new Date().toLocaleTimeString()} · ${topArticles.length} STORIES`;
        
    } catch (error) {
        console.error("Fetch error:", error);
        feedDiv.innerHTML = '<div class="loading-state" style="color:#FFD700;">❌ NETWORK ERROR<br><span style="font-size:10px;">Check your internet connection and API key.</span></div>';
        document.getElementById("articleCount").innerHTML = "ERROR";
    }
    
    isLoading = false;
}

function setupNavigation() {
    const buttons = document.querySelectorAll('.nav-item');
    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
            buttons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const category = btn.getAttribute('data-cat');
            loadNews(category);
        });
    });
    
    const topicTags = document.querySelectorAll('.topic-tag');
    topicTags.forEach(tag => {
        tag.addEventListener('click', () => {
            const cat = tag.getAttribute('data-cat');
            if (cat) {
                const targetBtn = document.querySelector(`.nav-item[data-cat="${cat}"]`);
                if (targetBtn) {
                    document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
                    targetBtn.classList.add('active');
                    loadNews(cat);
                }
            }
        });
    });
}

function startAutoRefresh() {
    setInterval(() => {
        if (!isLoading) {
            loadNews(currentCategory);
        }
    }, 10 * 60 * 1000);
}

setupNavigation();
loadNews('general');
startAutoRefresh();
</script>
